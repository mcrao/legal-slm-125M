# Copy to .env.local and fill in your own values. NEVER commit .env.local.
#
# Modal API token (dashboard → Settings → API Tokens). Alternatively just run
# `modal token new` once, which writes ~/.modal.toml and makes these optional.
MODAL_TOKEN_ID=ak-XXXXXXXXXXXXXXXX
MODAL_TOKEN_SECRET=as-XXXXXXXXXXXXXXXX

# Hugging Face token with WRITE role (huggingface.co/settings/tokens).
# Only needed to push the trained model in Phase 6.
HUGGINGFACE_TOKEN=hf_XXXXXXXXXXXXXXXX
